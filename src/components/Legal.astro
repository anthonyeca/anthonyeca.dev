---
import type { Lang } from '../i18n/content'
import { legalRoutes } from '../i18n/content'
import { otherLang } from '../i18n/utils'
import { SITE } from '../consts'
import Layout from '../layouts/Layout.astro'
import Header from './Header.astro'
import Footer from './Footer.astro'

interface Props {
  lang: Lang
  kind: 'privacy' | 'legal'
  title: string
  description: string
  /** Human-readable date, e.g. "24 de junio de 2026". */
  updated: string
}

const { lang, kind, title, description, updated } = Astro.props
const altUrl = legalRoutes[otherLang(lang)][kind]
const updatedLabel = lang === 'es' ? 'Última actualización' : 'Last updated'
---

<Layout lang={lang} title={`${title} | ${SITE.name}`} description={description}>
  <span id="top" class="absolute top-0"></span>
  <Header lang={lang} altUrl={altUrl} />

  <main class="px-4">
    <article class="legal-prose mx-auto w-full max-w-3xl pb-16 pt-36 md:pb-24 md:pt-44">
      <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h1>
      <p class="mt-3 text-sm text-zinc-500">{updatedLabel}: {updated}</p>
      <div class="mt-10 text-zinc-300">
        <slot />
      </div>
    </article>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .legal-prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #fff;
  }
  .legal-prose :global(h2:first-child) {
    margin-top: 0;
  }
  .legal-prose :global(p) {
    margin-top: 1rem;
    line-height: 1.7;
  }
  .legal-prose :global(ul) {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .legal-prose :global(li) {
    margin-top: 0.4rem;
    line-height: 1.7;
  }
  .legal-prose :global(a) {
    color: #34d399;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .legal-prose :global(a:hover) {
    color: #6ee7b7;
  }
  .legal-prose :global(strong) {
    color: #fff;
    font-weight: 600;
  }
</style>
