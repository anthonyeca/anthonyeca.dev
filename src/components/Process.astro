---
import type { Lang } from '../i18n/content'
import { useContent } from '../i18n/utils'
import SectionHeading from './SectionHeading.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useContent(lang)
---

<SectionHeading eyebrow={t.process.eyebrow} title={t.process.title} subtitle={t.process.subtitle} />

<ol class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
  {
    t.process.steps.map((step) => (
      <li class="relative rounded-2xl border border-white/10 bg-zinc-900/40 p-6">
        <span class="text-4xl font-extrabold text-emerald-400/70">{step.step}</span>
        <h3 class="mt-3 text-lg font-semibold text-white">{step.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-zinc-400">{step.description}</p>
      </li>
    ))
  }
</ol>
