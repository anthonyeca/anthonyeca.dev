---
import type { Credential } from '../i18n/content'

type Props = Credential

const { title, company, description, date } = Astro.props
---

<div class="relative pl-8">
  <span class="absolute left-0 top-1.5 flex size-3.5 items-center justify-center">
    <span class="size-3.5 rounded-full border-2 border-emerald-400 bg-zinc-950"></span>
  </span>
  <time class="text-xs font-semibold uppercase tracking-wider text-emerald-400/90">{date}</time>
  <h4 class="mt-1 text-lg font-semibold text-white">{title}</h4>
  {company && <p class="text-sm font-medium text-zinc-400">{company}</p>}
  <p class="mt-2 text-sm leading-relaxed text-zinc-400">{description}</p>
</div>
