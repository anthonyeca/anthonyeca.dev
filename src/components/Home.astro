---
import type { Lang } from '../i18n/content'
import { useContent } from '../i18n/utils'
import Layout from '../layouts/Layout.astro'
import Section from './Section.astro'
import Header from './Header.astro'
import Hero from './Hero.astro'
import Services from './Services.astro'
import Process from './Process.astro'
import About from './About.astro'
import Projects from './Projects.astro'
import Faq from './Faq.astro'
import CTA from './CTA.astro'
import Footer from './Footer.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useContent(lang)
---

<Layout lang={lang} title={t.meta.title} description={t.meta.description}>
  <span id="top" class="absolute top-0"></span>
  <Header lang={lang} />

  <main class="px-4">
    <section class="mx-auto w-full max-w-6xl pb-16 pt-36 md:pb-24 md:pt-44">
      <Hero lang={lang} />
    </section>

    <Section id="services"><Services lang={lang} /></Section>
    <Section id="process"><Process lang={lang} /></Section>
    <Section id="about"><About lang={lang} /></Section>
    <Section id="work"><Projects lang={lang} /></Section>
    <Section id="faq"><Faq lang={lang} /></Section>
    <Section id="contact" width="narrow"><CTA lang={lang} /></Section>
  </main>

  <Footer lang={lang} />
</Layout>
