---
import type { Lang } from '../i18n/content'
import { useContent } from '../i18n/utils'
import { SITE, MAILTO } from '../consts'
import Button from './Button.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useContent(lang)
---

<div class="relative overflow-hidden rounded-3xl border border-emerald-400/20 bg-linear-to-br from-emerald-400/15 via-zinc-900/40 to-zinc-900/40 px-6 py-14 text-center sm:px-12 sm:py-16">
  <div class="pointer-events-none absolute -top-20 left-1/2 size-72 -translate-x-1/2 rounded-full bg-emerald-400/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-2xl">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{t.cta.title}</h2>
    <p class="mt-4 text-lg text-zinc-300">{t.cta.subtitle}</p>

    <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Button href={MAILTO}>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z" />
          <path d="m3 6 9 7 9-7" />
        </svg>
        {t.cta.email}
      </Button>
      <Button href={SITE.linkedin} variant="secondary" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14ZM8.34 18.34V9.99H5.67v8.35h2.67ZM7 8.82a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1Zm11.34 9.52v-4.57c0-2.45-1.31-3.59-3.06-3.59-1.41 0-2.04.78-2.39 1.32v-1.13h-2.67c.04.75 0 8.35 0 8.35h2.67v-4.66c0-.24.02-.48.09-.65.19-.48.63-.97 1.36-.97.96 0 1.34.73 1.34 1.8v4.48h2.67Z" />
        </svg>
        {t.cta.linkedin}
      </Button>
    </div>
  </div>
</div>
