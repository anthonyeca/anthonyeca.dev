---
interface Props {
  href: string
  variant?: 'primary' | 'secondary'
  class?: string
  [key: string]: unknown
}

const { href, variant = 'primary', class: className = '', ...rest } = Astro.props

const base =
  'inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-base font-semibold transition'

const variants = {
  primary: 'bg-emerald-400 text-zinc-950 shadow-lg shadow-emerald-400/20 hover:bg-emerald-300',
  secondary: 'border border-white/15 text-white hover:border-emerald-400/50 hover:text-emerald-400',
}
---

<a href={href} class={`${base} ${variants[variant]} ${className}`} {...rest}>
  <slot />
</a>